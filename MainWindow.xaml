<Window x:Class="Aneis_e_estruturas_de_OTM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Aneis_e_estruturas_de_OTM"
        mc:Ignorable="d"
        Title="Estruturas OTM" Height="450" Width="800" Background="AliceBlue">

    <Border BorderBrush="Gray" BorderThickness="2" Padding="20" CornerRadius="10">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Estruturas de otimização" Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="4"  HorizontalAlignment="Center" FontSize="15" FontFamily="Arial" FontWeight="ExtraBlack" VerticalAlignment="Center"/>


            <Button Content="Open patient" Grid.Row="1" Grid.Column="0"  FontSize="12" FontWeight="Bold" Margin="5,0,0,0" Width="80" Height="20" HorizontalAlignment="Left" Click="Button_Click" />

            <TextBox x:Name="textBox1" HorizontalAlignment="Left" Margin="100,0,0,0" Width="400" Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="1" VerticalAlignment="Center"/>

            <TextBlock Text="StructureSet" Grid.Column="0" Grid.Row="2" HorizontalAlignment="Center" FontSize="12" FontWeight="Bold"/>

            <ComboBox x:Name="comboBox4" Grid.Column="0" Grid.Row="2" Margin="0,20,0,0" HorizontalAlignment="Center" Width="120" Height="20" SelectionChanged="comboBox4_SelectionChanged"/>

            <StackPanel Grid.Column="0" Grid.Row="3" HorizontalAlignment="Center" >
                <TextBlock Text="Structure" FontSize="12" FontWeight="Bold" FontFamily="arial" HorizontalAlignment="Center" Grid.Row="3" Height="20" Margin="0,10,0,0"/>
            </StackPanel>

            <ComboBox x:Name="comboBox1" Width="120" Height="20" Grid.Row="3" Grid.Column="0" Margin="0,30,0,0"/>

            <Image Grid.Column="3" HorizontalAlignment="Left" Height="100" Margin="156,0,0,0" Grid.RowSpan="3" VerticalAlignment="Center" Width="100" Source="/cosmo ninja.png"/>

            <TextBlock Text="Margin from structure (mm)" FontSize="12" FontWeight="Bold" FontFamily="arial" HorizontalAlignment="Center" Grid.Row="3" Grid.Column="1" Height="20" Margin="0,10,0,0" VerticalAlignment="Top"/>

            <ComboBox x:Name="comboBox2" Grid.Row="3" Grid.Column="1" Width="120" Height="20" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="20,33,0,0" SelectionChanged="comboBox2_SelectionChanged"/>

            <TextBlock Text="Ring Size (mm)" FontSize="12" FontWeight="Bold" FontFamily="arial" HorizontalAlignment="Center" Grid.Row="3" Grid.Column="2" Height="20" Margin="0,10,0,0" VerticalAlignment="Top"/>

            <ComboBox x:Name="comboBox3" Grid.Row="3" Grid.Column="2" Width="120" Height="20" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="20,33,0,0" SelectionChanged="comboBox3_SelectionChanged"/>

            <Button Content="Create ring" FontWeight="Bold" Click="Button_Click2" Grid.Column="0" Grid.Row="4" Height="20" Width="100" Margin="0,20,0,0" Background="#FF83F6F2"/>

            <Button Content="Crop Structure" FontWeight="Bold" Click="Button_CropOARs_Click" Grid.Column="1" Grid.Row="4" Height="20" Width="100" Margin="0,20,0,0" Background="#FF83F6F2" HorizontalAlignment="Center"/>

        </Grid>
    </Border>
</Window>
